# Copy this file to .env and fill real SMTP values.
# Backend auto-loads .env on startup.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@example.com

# Optional SMTP switches:
# SMTP_PROTOCOL=auto  # auto|starttls|smtp|smtps
# SMTP_USE_SSL=false
# SMTP_DISABLE_STARTTLS=false
